// Run on UCR HPCC (SLURM) with the helloworld Singularity container.
//
// Pre-req: helloworld.sif already on HPCC at process.container path below.
// Build/ship it from a laptop via:  make hello_all_hpcc
//
// Override the container path on the command line if you want to point at
// a different .sif:  nextflow run ... --container_sif /path/to/your.sif

params.container_sif = '/bigdata/mxwanglab/mingxunw/helloworld_container/helloworld.sif'

process.executor      = 'slurm'
process.container     = params.container_sif
process.clusterOptions = '--partition=short --time=00:10:00 --mem=1G'
// HPCC compute nodes don't have singularity on PATH by default; load the
// module inside the SLURM job wrapper so `singularity exec` resolves.
process.module        = 'singularity/4.3.2'

singularity {
    enabled    = true
    autoMounts = true
    // Cache on /bigdata, not /rhome (small quota). Override per-user.
    cacheDir   = "${System.getenv('HOME')}/.singularity_cache"
}
